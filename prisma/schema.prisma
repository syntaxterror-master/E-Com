generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model User { 
  id    Int     @id @default(autoincrement()) 
  name  String
  lastname String
  email String  @unique
  password String
  role Role @default(USER)
  whislist Whislist[]
  orders Order[]
  products Product[]
  ratings Rating[]
} 

enum Role {
  USER
  ADMIN
}

model Whislist { 
  id        Int     @id @default(autoincrement()) 
  products Product[]
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id]) 
} 

model Order { 
  id        Int     @id @default(autoincrement()) 
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id])
  products Product[]
  
} 

model Product { 
  id        Int     @id @default(autoincrement()) 
  title     String
  description   String?
  image String?
  published Boolean @default(false)
  price Decimal @db.Decimal(10, 2)
  discount_amount Decimal @db.Decimal(10, 2)
  discount Int
  whislist Whislist[]
  order Order[]
  ratings Rating[]
  category Category @relation(fields: [categoryId], references: [id])
  categoryId Int
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id]) 
} 

model Rating { 
  id  Int     @id @default(autoincrement()) 
  testimonial String
  published Boolean @default(false)
  product Product @relation(fields: [productId], references: [id])
  productId Int
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id]) 
} 

model Category { 
  id        Int     @id @default(autoincrement()) 
  name     String
  products Product[]
} 

